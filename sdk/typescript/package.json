{
  "name": "@altf4llc/vorpal-sdk",
  "version": "0.1.0-rc.2",
  "description": "Vorpal SDK for building artifacts in TypeScript",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ALT-F4-LLC/vorpal",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/ALT-F4-LLC/vorpal/tree/main/sdk/typescript",
  "bugs": {
    "url": "https://github.com/ALT-F4-LLC/vorpal/issues"
  },
  "keywords": [
    "vorpal",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "generate:proto": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/api --ts_proto_opt=outputServices=grpc-js --ts_proto_opt=esModuleInterop=true --ts_proto_opt=snakeToCamel=false --ts_proto_opt=forceLong=number --ts_proto_opt=useOptionals=messages --ts_proto_opt=oneof=unions --ts_proto_opt=env=node --ts_proto_opt=importSuffix=.js -I ../rust/api ../rust/api/agent/agent.proto ../rust/api/archive/archive.proto ../rust/api/artifact/artifact.proto ../rust/api/context/context.proto ../rust/api/worker/worker.proto",
    "test": "bun test",
    "validate:proto": "npx tsx scripts/validate-serialization.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@grpc/grpc-js": "1.14.3",
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "ts-proto": "2.11.6",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
