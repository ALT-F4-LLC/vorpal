      "steps": [
        {
          "entrypoint": "/bin/sh",
          "script": "make install",
          "secrets": [{ "name": "API_KEY", "value": "secret123" }],
          "arguments": ["--verbose"],
          "artifacts": ["dep1", "dep2"],
          "environments": ["PATH=/usr/bin"]
        }
      ],
      "systems": [1, 4],
      "aliases": ["myapp:1.0.0"],
      "name": "myapp"
    }
  },
