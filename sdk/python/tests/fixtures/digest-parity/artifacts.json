  {
    "name": "full",
    "comment": "Fully populated artifact; mirrors the Go FullArtifact test. digest/entrypoint/script all PRESENT.",
    "artifact": {
      "target": 1,
      "sources": [
        {
          "digest": "abc123",
          "excludes": ["*.tmp"],
          "includes": ["src/**"],
          "name": "main",
          "path": "https://example.com/source.tar.gz"
